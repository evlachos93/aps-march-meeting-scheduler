# APS Scheduler Environment Variables

# API Server
PORT=3000

# Web App
VITE_API_BASE=http://localhost:3000

# Scraper Options
SCRAPER_MAX_EVENTS=
SCRAPER_EVENT_TYPES=ALL
SCRAPER_MEETING_PREFIX=
SCRAPER_OUTPUT_FILE=data/talks.json
SCRAPER_CONCURRENCY=10
SCHEDULE_TIME_ZONE=America/Denver

# Session Generation
SESSIONS_SKIP_EVENT_INDEX=0

# LLM Filtering Configuration
# Set to 1 to enable LLM filtering (requires API_URL and API_KEY)
SESSIONS_LLM_FILTER=0
SESSIONS_LLM_API_URL=
SESSIONS_LLM_API_KEY=
SESSIONS_LLM_MODEL=gpt-4o-mini
SESSIONS_LLM_BATCH_SIZE=20
